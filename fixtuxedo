#!/bin/bash

# ============================================================
# TUXEDO boot-time fixup script
# ============================================================
# This script runs before tccd.service at boot to:
#   1. Create the /opt symlink for Tuxedo Control Center
#   2. Unload the built-in uniwill_laptop module if it slipped
#      past the modprobe blacklist, then load tuxedo-drivers
#      modules in the correct order.
# ============================================================

set -e

# Create /opt symlink for Tuxedo Control Center
if [ ! -L "/opt/tuxedo-control-center" ]; then
    ln -s /usr/share/tuxedo-control-center /opt/tuxedo-control-center
    echo "Tuxedo Control Center linked to /opt directory"
else
    echo "Tuxedo symlink at /opt already exists, no fix needed"
fi

# ============================================================
# Unbind and unload the built-in uniwill_laptop module if it
# managed to load before the blacklist took effect, then load
# the tuxedo-drivers modules.
# ============================================================
WMI_DEVICE="ABBC0F72-8EA1-11D1-00A0-C90629100000-8"

if lsmod | grep -q "uniwill_laptop"; then
    echo "uniwill_laptop is loaded, unbinding and removing..."

    # Unbind from the WMI device if bound
    if [ -d "/sys/bus/wmi/drivers/uniwill_laptop" ]; then
        if ls /sys/bus/wmi/drivers/uniwill_laptop/ | grep -q "${WMI_DEVICE}"; then
            echo "${WMI_DEVICE}" > /sys/bus/wmi/drivers/uniwill_laptop/unbind 2>/dev/null || true
        fi
    fi

    # Remove the module
    modprobe -r uniwill_laptop 2>/dev/null || rmmod uniwill_laptop 2>/dev/null || true
    echo "uniwill_laptop removed"
fi

# Load tuxedo-drivers modules in dependency order (best-effort)
for mod in tuxedo_compatibility_check uniwill_wmi clevo_wmi tuxedo_io tuxedo_keyboard; do
    if ! lsmod | grep -q "^${mod}\b"; then
        modprobe "${mod}" 2>/dev/null || true
    fi
done

echo "Tuxedo boot-time fixup completed"